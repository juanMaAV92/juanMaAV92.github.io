---
import type { Repo } from '../data/repos';

interface Props {
  items: Repo[];
}
const { items } = Astro.props;
---

<ul class="repo-list">
  {items.map((repo) => {
    const internal = !!repo.page;
    const href = repo.page ?? repo.url;
    return (
      <li class="repo reveal" data-featured={repo.featured} data-internal={internal}>
        <a class="repo-link" href={href} {...(internal ? {} : { target: '_blank', rel: 'noopener' })}>
          <div class="repo-top">
            <span class="arrow" aria-hidden="true">▸</span>
            <span class="repo-name">{repo.name}</span>
            {internal && <span class="repo-badge">page</span>}
            <span class="tags">
              {repo.tags.map((t) => <span class="tag">{t}</span>)}
            </span>
            <span class="goto" aria-hidden="true">{internal ? '→' : '↗'}</span>
          </div>
          <p class="repo-desc">{repo.description}</p>
        </a>
      </li>
    );
  })}
</ul>
